# ============================================================
# BRIKII — Variables d'environnement
# Copier ce fichier en .env.local et renseigner les valeurs
# NE JAMAIS commiter .env.local
# ============================================================

# --- APPLICATION ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POOLS_IMMO_URL=http://localhost:3001
NODE_ENV=development

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# --- CLOUDFLARE IMAGES ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_HASH=
CLOUDFLARE_IMAGES_BASE_URL=https://images.brikii.fr

# --- RESEND (emails) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@brikii.fr
RESEND_FROM_NAME=Brikii

# --- TWILIO (SMS / OTP) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+33...

# --- STRIPE ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- MAPBOX ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# --- UPSTASH REDIS (rate limiting) ---
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=

# --- N8N (scraping annonces) ---
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/recup-infos-annonce
N8N_WEBHOOK_SECRET=

# --- SENTRY (monitoring erreurs) ---
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- API ADRESSE GOUV.FR (géocodage — pas de clé requise) ---
NEXT_PUBLIC_API_ADRESSE_URL=https://api-adresse.data.gouv.fr

# --- SIRENE INSEE (recherche agences — compte gratuit sur api.insee.fr) ---
SIRENE_API_TOKEN=
